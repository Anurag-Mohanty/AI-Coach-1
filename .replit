entrypoint = "ui.py"
modules = ["python-3.11"]

run = "streamlit run ui.py --server.port 3000 --server.address 0.0.0.0"

[nix]
channel = "stable-24_05"

[unitTest]
language = "python3"

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]

[deployment]
run = ["python3", "main.py"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 3000
externalPort = 80

[workflows]
runButton = "Test Domain Jump"

[[workflows.workflow]]
name = "Resume UI"
author = 21639534
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run resume_ui.py --server.port 3000 --server.address 0.0.0.0"

[[workflows.workflow]]
name = "Resume View"
author = 21639534
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PYTHONPATH=/home/runner/workspace streamlit run pages/resume_view.py --server.port 3000 --server.address 0.0.0.0"

[[workflows.workflow]]
name = "Main App"
author = 21639534
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PYTHONPATH=/home/runner/workspace streamlit run main.py --server.port 3000 --server.address 0.0.0.0"

[[workflows.workflow]]
name = "Role Detail View"
author = 21639534
mode = "sequential"

[[workflows.workflow.tasks]]
