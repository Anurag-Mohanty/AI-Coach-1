mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PYTHONPATH=/home/runner/workspace streamlit run pages/content_view.py --server.port 3000 --server.address 0.0.0.0 --server.baseUrlPath=\"\" --server.headless true"

